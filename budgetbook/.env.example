SECRET_KEY=change-me-to-a-random-string
DEBUG=False
# スマホや他端末からアクセスする場合は PC の LAN IP を追加してください
# 例: ALLOWED_HOSTS=127.0.0.1,localhost,192.168.1.10
ALLOWED_HOSTS=127.0.0.1,localhost

# --- 公開モード（HTTPS 環境向け） ---
# SECURE_COOKIES=1 にすると session / csrf cookie に Secure 属性が付きます。
# Cloudflare Tunnel 構成では有効化してください。
SECURE_COOKIES=1

# Content Security Policy は既定で有効です。
# 問題切り分け時のみ ENABLE_CSP=0 で一時停止できます。
# ENABLE_CSP=0

# ENABLE_HTTPS=1 にすると HSTS / SSL リダイレクトが有効になります。
# Cloudflare Tunnel 構成では通常 OFF のままにしてください（HTTPS は Cloudflare 側で強制）
# LAN 内 HTTP 運用でもコメントアウトのままにしてください
# ENABLE_HTTPS=1
#
# --- HSTS 段階的ロールアウト ----------------------------------------------------
# 短期(動作確認):    SECURE_HSTS_SECONDS=60         (60 秒。即時ロールバック可)
# 中期(1週間運用):  SECURE_HSTS_SECONDS=604800     (1週間)
# 本番(申請直前):   SECURE_HSTS_SECONDS=31536000   (1年。preload に必須)
# 各段階で挙動異常がないか確認してから次へ進めてください。
# 切り戻しはブラウザに残った HSTS が消えるまで一時的に HTTPS が強制されます。
# SECURE_HSTS_SECONDS=60
#
# HSTS preload は SECURE_HSTS_SECONDS=31536000 で1ヶ月以上安定運用したあとに有効化し、
# https://hstspreload.org/ で申請してください。一度申請すると除外に時間がかかります。
# ENABLE_HSTS_PRELOAD=1
# CSRF_TRUSTED_ORIGINS=https://kakeibo.example.com

# --- 管理画面 URL ---
# デフォルトは admin/ です。公開時は推測されにくいパスに変更してください
# ADMIN_URL_PATH=my-secret-admin/

# --- セッション ---
# セッション有効期間（秒）。デフォルト 86400（24 時間）
# SESSION_COOKIE_AGE=86400

# --- ログイン試行回数制限 (django-axes) ---
# AXES_FAILURE_LIMIT=5
# AXES_COOLOFF_TIME=0.5

# --- ロギング ---
# DJANGO_LOG_FORMAT=json で構造化ログを stdout に出力（運用既定）
# DJANGO_LOG_FORMAT=plain で人読み形式
# DJANGO_LOG_LEVEL=INFO|WARNING|ERROR
# DJANGO_LOG_FORMAT=json
# DJANGO_LOG_LEVEL=INFO

# --- 二次レート制限 (axes に加える defense-in-depth) ---
# RATE_LIMIT_ENABLED=1
# RATE_LIMIT_MAX_EVENTS=600
# RATE_LIMIT_WINDOW_SECONDS=60

# --- Docker / Cloudflare Tunnel 運用例 ---
# DB ファイルのパス。ローカル開発では未指定で OK（BASE_DIR/db.sqlite3 を使用）。
# Docker では永続化ディレクトリ配下を指定してください。
# DJANGO_DB_PATH=/app/data/db.sqlite3

# SQLite 本番運用のロック対策。本人/妻の小規模利用でも維持してください。
SQLITE_BUSY_TIMEOUT_MS=5000
SQLITE_JOURNAL_MODE=WAL
SQLITE_SYNCHRONOUS=NORMAL

# Cloudflare Tunnel など信頼できるリバースプロキシ配下のときのみ 1 にする。
# Django 側で SSL リダイレクトはしない（ループ防止）。HTTPS 化は Cloudflare 側で強制する。
TRUST_PROXY_SSL=1

# 公開ホスト名と CSRF Trusted Origins の例:
# ALLOWED_HOSTS=127.0.0.1,localhost,kakeibo.example.com
# CSRF_TRUSTED_ORIGINS=https://kakeibo.example.com

# --- Cloudflare Tunnel token ---
# このアプリの compose には含めません。Ubuntu host 側 systemd の cloudflared サービスで
# `cloudflared service install <TOKEN>` または /etc/cloudflared/config.yml で管理してください。
# Token は絶対に Git 管理しないでください。
